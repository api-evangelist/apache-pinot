{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-pinot/refs/heads/main/json-structure/apache-pinot-table-config-structure.json",
  "description": "TableConfig schema from Apache Pinot",
  "type": "object",
  "properties": {
    "tableName": {
      "type": "string",
      "example": "myTable"
    },
    "tableType": {
      "type": "string",
      "enum": [
        "OFFLINE",
        "REALTIME"
      ],
      "example": "OFFLINE"
    },
    "segmentsConfig": {
      "type": "object",
      "properties": {
        "replication": {
          "type": "string",
          "example": "1"
        },
        "timeColumnName": {
          "type": "string"
        }
      }
    },
    "tenants": {
      "type": "object",
      "properties": {
        "broker": {
          "type": "string",
          "example": "DefaultTenant"
        },
        "server": {
          "type": "string",
          "example": "DefaultTenant"
        }
      }
    }
  },
  "name": "TableConfig"
}