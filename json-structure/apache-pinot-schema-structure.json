      }
    },
    "metricFieldSpecs": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/FieldSpec"
      }
    },
    "dateTimeFieldSpecs": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/FieldSpec"
      }
    }
  },
  "name": "Schema"
}