{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-pinot/refs/heads/main/json-structure/apache-pinot-field-spec-structure.json",
  "description": "FieldSpec schema from Apache Pinot",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "example": "AirlineID"
    },
    "dataType": {
      "type": "string",
      "enum": [
        "INT",
        "LONG",
        "FLOAT",
        "DOUBLE",
        "STRING",
        "BYTES",
        "BOOLEAN",
        "TIMESTAMP",
        "JSON"
      ],
      "example": "INT"
    },
    "notNull": {
      "type": "boolean",
      "example": false
    }
  },
  "name": "FieldSpec"
}